{
  "name": "photo-organizer",
  "version": "1.0.0",
  "author": "Photo Organizer User",
  "description": "로컬 사진 폴더 자동 정리 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win --publish never",
    "build-mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exifr": "^7.1.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "publish": null,
    "appId": "com.photoorganizer.app",
    "productName": "Photo Organizer",
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Photo Organizer"
    },
    "portable": {
      "artifactName": "PhotoOrganizer-${version}.exe"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.photography"
    }
  }
}
